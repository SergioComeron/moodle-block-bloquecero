@media (max-width: 600px) {
    /* Reducir el tamaño de la fuente de títulos y botones */
    .section-title-header {
        font-size: 0.85em;
        padding: 10px 12px;
    }
    .section-title-header .section-title-text {
        font-size: 0.85em;
    }
    .carousel-btn {
        font-size: 1.2em;
    }
    .round-button {
        width: 32px;
        height: 32px;
        min-width: 32px;
        min-height: 32px;
        font-size: 1em;
    }
    /* Ajustar tarjetas de secciones */
    .section-card {
        flex: 0 0 calc((100% - 36px) / 2); /* Por ejemplo, dejar 2 tarjetas por fila */
        max-width: calc((100% - 36px) / 2);
        min-width: calc((100% - 36px) / 2);
    }
    /* Ajustar estilos en bloques de "Sesiones en directo" y "Calendario de actividades" */
    .ghost-button, .forum-card, .calendario-actividades-container, .section-activities {
        font-size: 0.85em;
    }
}