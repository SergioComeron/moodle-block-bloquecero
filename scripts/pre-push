#!/usr/bin/env bash
#
# Hook pre-push para block_bloquecero.
# - Ejecuta code sniffer y tests PHPUnit antes de cada push.
# - En push a master: bump automático de version.php y commit.
#
# Instalación: bash scripts/install-hooks.sh

set -e

# Capturar refs de stdin antes de que se consuman
PUSH_REFS=$(cat)

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PHPCS="${PLUGIN_DIR}/vendor/bin/phpcs"

# Detectar la raíz de Moodle para ejecutar PHPUnit.
# El plugin es un repo standalone (~/moodles/plugins/block_bloquecero) symlinkeado
# dentro de varias instalaciones Moodle, así que el clásico "../.." ya no aplica.
detect_moodle_root() {
    # 1. Override manual por variable de entorno.
    if [ -n "${BLOCK_BLOQUECERO_MOODLE_ROOT}" ] && [ -f "${BLOCK_BLOQUECERO_MOODLE_ROOT}/vendor/bin/phpunit" ]; then
        echo "${BLOCK_BLOQUECERO_MOODLE_ROOT}"
        return 0
    fi
    # 2. Layout clásico: el plugin vive dentro del árbol Moodle (blocks/bloquecero).
    local classic
    classic="$(cd "${PLUGIN_DIR}/../.." 2>/dev/null && pwd)"
    if [ -n "${classic}" ] && [ -f "${classic}/vendor/bin/phpunit" ] && [ -f "${classic}/version.php" ]; then
        echo "${classic}"
        return 0
    fi
    # 3. Layout standalone: probar instalaciones candidatas conocidas.
    # Se prefiere la versión más nueva con PHPUnit instalado; las que no lo
    # tengan se saltan automáticamente.
    local candidates=(
        "${HOME}/moodles/stable_502/moodle"
        "${HOME}/moodles/stable_405/moodle"
        "${HOME}/moodles/stable_501/moodle"
        "${HOME}/moodles/stable_main/moodle"
    )
    local c
    for c in "${candidates[@]}"; do
        if [ -f "${c}/vendor/bin/phpunit" ]; then
            echo "${c}"
            return 0
        fi
    done
    return 1
}

MOODLE_ROOT="$(detect_moodle_root || true)"
PHPUNIT="${MOODLE_ROOT}/vendor/bin/phpunit"

# --- Code sniffer ---

if [ ! -f "${PHPCS}" ]; then
    echo "⚠️  phpcs no encontrado en ${PHPCS}"
    echo "   Asegúrate de haber ejecutado 'composer install' en el directorio del plugin."
    exit 1
fi

echo "▶ Ejecutando code sniffer..."

cd "${PLUGIN_DIR}"
"${PHPCS}" --standard=phpcs.xml

if [ $? -ne 0 ]; then
    echo ""
    echo "✗ Errores de code style. Push cancelado."
    echo "  Ejecuta: vendor/bin/phpcbf --standard=phpcs.xml"
    exit 1
fi

echo "✓ Code style correcto."

# --- PHPUnit ---

if [ -z "${MOODLE_ROOT}" ] || [ ! -f "${PHPUNIT}" ]; then
    echo "⚠️  PHPUnit no encontrado: no se localizó una instalación Moodle con vendor/bin/phpunit."
    echo "   Se omite la ejecución de tests (solo se ha validado el code style)."
    echo "   Para forzar una raíz Moodle: export BLOCK_BLOQUECERO_MOODLE_ROOT=/ruta/a/moodle"
else
    echo "▶ Ejecutando tests PHPUnit (${MOODLE_ROOT})..."

    cd "${MOODLE_ROOT}"

    set +e
    PHPUNIT_OUTPUT=$(php "${PHPUNIT}" --testsuite block_bloquecero_testsuite 2>&1)
    PHPUNIT_EXIT=$?
    set -e

    if echo "${PHPUNIT_OUTPUT}" | grep -q "initialised for different version"; then
        echo "  Entorno PHPUnit desactualizado. Reinicializando..."
        # En Moodle 5.x el código vive bajo public/; en 4.5 está en la raíz.
        if [ -f public/admin/tool/phpunit/cli/init.php ]; then
            php public/admin/tool/phpunit/cli/init.php 2>&1 | tail -3
        else
            php admin/tool/phpunit/cli/init.php 2>&1 | tail -3
        fi
        echo "  Reejecutando tests..."
        set +e
        PHPUNIT_OUTPUT=$(php "${PHPUNIT}" --testsuite block_bloquecero_testsuite 2>&1)
        PHPUNIT_EXIT=$?
        set -e
    fi

    echo "${PHPUNIT_OUTPUT}"

    if [ $PHPUNIT_EXIT -ne 0 ]; then
        echo ""
        echo "✗ Tests fallidos. Push cancelado."
        echo "  Corrige los errores antes de volver a hacer push."
        exit 1
    fi

    echo "✓ Todos los tests pasan."
fi

# --- Auto version bump cuando push a master ---

PUSH_TO_MASTER=false
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_ref" == "refs/heads/master" ]]; then
        PUSH_TO_MASTER=true
    fi
done <<< "$PUSH_REFS"

if [ "$PUSH_TO_MASTER" = true ]; then
    echo ""
    echo "▶ Push a master detectado. Comprobando versión..."

    VERSION_FILE="${PLUGIN_DIR}/version.php"

    # Sincronizar tags remotos antes de comprobar (el CI puede haber creado tags nuevos)
    git -C "${PLUGIN_DIR}" fetch --tags --quiet 2>/dev/null || true

    CURRENT_RELEASE=$(grep "\$plugin->release" "${VERSION_FILE}" | sed "s/.*'\([^']*\)'.*/\1/")

    # Si ya existe el tag v{CURRENT_RELEASE} o el último commit es un bump, no bumpar de nuevo
    LAST_COMMIT=$(git -C "${PLUGIN_DIR}" log -1 --pretty=format:"%s")
    TAG_EXISTS=$(git -C "${PLUGIN_DIR}" tag -l "v${CURRENT_RELEASE}")
    if [[ -n "$TAG_EXISTS" || "$LAST_COMMIT" == Release:\ bump\ version* ]]; then
        echo "✓ Versión ya bumpeada (${CURRENT_RELEASE}). Continuando con el push."
    else
        # Leer build actual
        CURRENT_BUILD=$(grep "\$plugin->version" "${VERSION_FILE}" | sed 's/[^0-9]*\([0-9]\{10\}\).*/\1/')

        # Analizar commits desde el último tag para determinar el tipo de bump
        LAST_TAG=$(git -C "${PLUGIN_DIR}" describe --tags --abbrev=0 2>/dev/null || echo "")
        if [ -n "$LAST_TAG" ]; then
            COMMITS=$(git -C "${PLUGIN_DIR}" log "${LAST_TAG}..HEAD" --pretty=format:"%s" --no-merges)
        else
            COMMITS=$(git -C "${PLUGIN_DIR}" log --pretty=format:"%s" --no-merges)
        fi

        BUMP="patch"
        FEAT_RE='^[Ff]eat[:(]'
        while IFS= read -r commit_msg; do
            if [[ "$commit_msg" =~ $FEAT_RE ]]; then
                BUMP="minor"
                break
            fi
        done <<< "$COMMITS"

        # Parsear versión semántica (soporta X.Y y X.Y.Z)
        IFS='.' read -ra PARTS <<< "$CURRENT_RELEASE"
        MAJOR=${PARTS[0]:-0}
        MINOR=${PARTS[1]:-0}
        PATCH=${PARTS[2]:-0}

        if [ "$BUMP" = "minor" ]; then
            MINOR=$((MINOR + 1))
            NEW_RELEASE="${MAJOR}.${MINOR}"
        else
            PATCH=$((PATCH + 1))
            NEW_RELEASE="${MAJOR}.${MINOR}.${PATCH}"
        fi

        # Calcular nuevo número de build (YYYYMMDDXX)
        TODAY=$(date +%Y%m%d)
        if [[ "$CURRENT_BUILD" == ${TODAY}* ]]; then
            SEQ="${CURRENT_BUILD: -2}"
            NEW_BUILD="${TODAY}$(printf '%02d' $((10#$SEQ + 1)))"
        else
            NEW_BUILD="${TODAY}00"
        fi

        echo "   Versión:  ${CURRENT_RELEASE} → ${NEW_RELEASE}  (bump: ${BUMP})"
        echo "   Build:    ${CURRENT_BUILD} → ${NEW_BUILD}"

        # Actualizar version.php con Python para evitar problemas de escaping en sed
        python3 - "${VERSION_FILE}" "${NEW_BUILD}" "${NEW_RELEASE}" << 'PYEOF'
import sys, re

filepath, new_build, new_release = sys.argv[1], sys.argv[2], sys.argv[3]

with open(filepath, 'r') as f:
    content = f.read()

content = re.sub(r'(\$plugin->version = )\d+', rf'\g<1>{new_build}', content)
content = re.sub(r"(\$plugin->release = ')[^']+(';)", rf"\g<1>{new_release}\g<2>", content)

with open(filepath, 'w') as f:
    f.write(content)
PYEOF

        git -C "${PLUGIN_DIR}" add version.php
        git -C "${PLUGIN_DIR}" commit -m "Release: bump version to ${NEW_RELEASE}"

        echo ""
        echo "✓ version.php bumpeado a ${NEW_RELEASE} y commiteado."
        echo "  Git no incluye commits del hook en el push actual."
        echo "  Vuelve a ejecutar: git push origin master"
        echo ""
        exit 1
    fi
fi

echo "▶ Continuando con el push."
exit 0
